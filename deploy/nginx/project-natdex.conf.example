# Replace example.com with your real domain names.
#
# play.example.com serves the static client.
# sim.example.com proxies WebSocket/HTTP traffic to the Showdown server.

map $http_upgrade $connection_upgrade {
	default upgrade;
	'' close;
}

server {
	listen 80;
	server_name play.example.com sim.example.com;
	return 301 https://$host$request_uri;
}

server {
	listen 443 ssl http2;
	server_name play.example.com;

	ssl_certificate /etc/letsencrypt/live/play.example.com/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/play.example.com/privkey.pem;

	root /opt/project-natdex/client/play.pokemonshowdown.com;
	index index.html;

	add_header X-Content-Type-Options nosniff;
	add_header Referrer-Policy strict-origin-when-cross-origin;

	location / {
		try_files $uri $uri/ /index.html;
	}

	location ~* \.(?:css|js|png|jpg|jpeg|gif|ico|svg|webp|woff2?)$ {
		try_files $uri =404;
		expires 7d;
		add_header Cache-Control "public";
	}
}

server {
	listen 443 ssl http2;
	server_name sim.example.com;

	ssl_certificate /etc/letsencrypt/live/sim.example.com/fullchain.pem;
	ssl_certificate_key /etc/letsencrypt/live/sim.example.com/privkey.pem;

	location / {
		proxy_pass http://127.0.0.1:8000;
		proxy_http_version 1.1;
		proxy_set_header Upgrade $http_upgrade;
		proxy_set_header Connection $connection_upgrade;
		proxy_set_header Host $host;
		proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
		proxy_set_header X-Forwarded-Proto $scheme;
		proxy_buffering off;
		proxy_read_timeout 3600;
	}
}
