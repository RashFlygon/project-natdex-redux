play.champsnatdex.dynv6.net {
	encode zstd gzip

	handle /showdown* {
		reverse_proxy 127.0.0.1:8000
	}

	@officialAssets path /sprites/* /audio/* /fx/*
	handle @officialAssets {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	@officialPhp path /~~* /action.php /customcss.php /ladder.php /crossdomain.php
	handle @officialPhp {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	root * /opt/project-natdex/client/play.pokemonshowdown.com

	# Important: do not fall back to index.html for missing static files.
	# This prevents missing JS/CSS/images from being returned as HTML, which causes
	# browser errors like "Unexpected token '<'" and missing globals like BattleScene.
	@staticFile path_regexp \.[A-Za-z0-9]{1,8}$
	handle @staticFile {
		file_server
	}

	# Only app/navigation paths should fall back to index.html.
	handle {
		try_files {path} {path}/ /index.html
		file_server
	}
}
