play.champsnatdex.dynv6.net {
	encode zstd gzip

	handle /showdown* {
		reverse_proxy 127.0.0.1:8000
	}

	handle /~~* {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	handle /action.php {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	handle /customcss.php {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	handle /ladder.php {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	handle /crossdomain.php {
		reverse_proxy https://play.pokemonshowdown.com {
			header_up Host play.pokemonshowdown.com
		}
	}

	handle {
		root * /opt/project-natdex/client/play.pokemonshowdown.com
		try_files {path} {path}/ /index.html
		file_server
	}
}
