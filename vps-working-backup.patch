-			if (this.side.battle.tier.includes('Champions')) {
+			if (this.side.battle.tier.includes('NatDex Champions (Modern)')) {
+				if (move.pp === 1 || move.noPPBoosts) maxpp = move.pp;
+				else if (move.id === 'protect' || move.pp <= 5) maxpp = 8;
